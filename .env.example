# ── Required ──────────────────────────────────────────────────────────────────
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-gemini-key-here

# Google retires Gemini model IDs on a rolling basis — check
# https://ai.google.dev/gemini-api/docs/deprecations before assuming this is
# still current. gemini-2.0-flash was retired June 1, 2026.
GEMINI_MODEL=gemini-2.5-flash

# ── Job search (strongly recommended — free) ─────────────────────────────────
# Free 250 calls/month, no credit card. Sign up at https://developer.adzuna.com/
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ── GitHub enrichment ─────────────────────────────────────────────────────────
# Without this: 60 req/hr, pinned repos unavailable (requires auth)
# Create at https://github.com/settings/tokens  (no scopes needed for public repos)
GITHUB_TOKEN=ghp_optional_for_higher_rate_limits_and_pinned_repos

# ── LinkedIn enrichment (optional) ───────────────────────────────────────────
# Uses the unofficial linkedin-api library (cookie-based auth).
# WITHOUT these: LinkedIn URL is stored as a link only; enrichment
#   falls back to public HTML scrape (limited) then paste-text (always works).
# WITH these: full profile data — experience, skills, education — is fetched.
# Use a secondary/test account to avoid rate-limiting your main account.
LINKEDIN_EMAIL=your-linkedin-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password

# ── Server config ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_UPLOAD_MB=10
PORT=8000

# Used automatically if Gemini returns a 429 (quota exceeded) or the Gemini
# key is missing. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# Groq deprecates model IDs fairly often — check
# https://console.groq.com/docs/models before assuming this is still current.
GROQ_MODEL=openai/gpt-oss-120b
